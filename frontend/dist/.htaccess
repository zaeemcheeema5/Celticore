# =====================================================================
# Performance config for the static build served from public_html/.
# This does not change any routing/functionality — only how assets are
# compressed and cached by the browser/CDN.
# =====================================================================

# ---------------------------------------------------------------------
# 1. Serve pre-built .br / .gz files when the browser supports them.
#    vite-plugin-compression (see frontend/vite.config.ts) generates a
#    .br and .gz sibling next to every JS/CSS/SVG file at build time, so
#    Apache can hand those over directly instead of compressing on the
#    fly on every single request.
# ---------------------------------------------------------------------
<IfModule mod_headers.c>
  <IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddEncoding br .br
    AddEncoding gzip .gz
  </IfModule>

  RewriteEngine On

  # Prefer Brotli
  RewriteCond %{HTTP:Accept-Encoding} br
  RewriteCond %{REQUEST_FILENAME}\.br -f
  RewriteRule ^(.*)$ $1\.br [L]

  # Fall back to gzip
  RewriteCond %{HTTP:Accept-Encoding} gzip
  RewriteCond %{REQUEST_FILENAME}\.gz -f
  RewriteRule ^(.*)$ $1\.gz [L]

  # Tell the browser/proxy the file it just got is already compressed and
  # what its real content-type is, since the .br/.gz rewrite above hides
  # the original extension from Apache's normal MIME detection.
  <FilesMatch "\.js\.(br|gz)$">
    Header set Content-Encoding "$1" env=applicable
    ForceType application/javascript
  </FilesMatch>
  <FilesMatch "\.css\.(br|gz)$">
    ForceType text/css
  </FilesMatch>
  <FilesMatch "\.br$">
    Header append Content-Encoding br
  </FilesMatch>
  <FilesMatch "\.gz$">
    Header append Content-Encoding gzip
  </FilesMatch>
  <FilesMatch "\.(js|css)\.(br|gz)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------
# 2. Live on-the-fly compression as a fallback for anything not covered
#    above (HTML, fonts, any asset without a pre-built .br/.gz).
# ---------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css
  AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>

# ---------------------------------------------------------------------
# 3. Cache lifetimes.
#    Vite fingerprints every file under /assets/ with a content hash, so
#    those can be cached "forever" — a new deploy produces new filenames,
#    it never reuses a stale one. index.html itself must NOT be cached
#    (or every deploy would be invisible to returning visitors), and the
#    (unhashed) product/category images from the API get a shorter,
#    still-useful cache window.
# ---------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType text/html "access plus 0 seconds"

  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"

  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Content-hashed build assets: safe to cache forever.
  <FilesMatch "^.+\.[a-fA-F0-9]{8,}\.(js|css|woff2?|png|jpe?g|webp|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # index.html: always revalidate so deploys show up immediately.
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
